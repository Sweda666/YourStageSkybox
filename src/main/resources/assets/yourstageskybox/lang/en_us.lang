yourstageskybox.command.list.empty=§eNo registered skyboxes.
yourstageskybox.command.list.hint=§7Place textures in resource pack: §fassets/yourstageskybox/textures/skyboxes/<name>/panorama_0~5.png §7then use §f/yourstageskybox set <name> §7to auto-register.
yourstageskybox.command.list.header=§aRegistered skyboxes (%1$d):
yourstageskybox.command.list.active= §6[active]
yourstageskybox.command.info.vanilla=§eDimension §f%1$d§e: §7(vanilla sky)
yourstageskybox.command.info.format=§eDimension §f%1$d§e: §f%2$s
